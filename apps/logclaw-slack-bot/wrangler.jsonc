{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "logclaw-slack-bot",
  "main": "src/index.ts",
  "compatibility_date": "2025-12-01",
  "compatibility_flags": ["nodejs_compat"],
  /**
   * Secrets (set via `npx wrangler secret put <NAME>`):
   *   SLACK_CLIENT_ID       — Slack app client ID
   *   SLACK_CLIENT_SECRET   — Slack app client secret
   *   SLACK_SIGNING_SECRET  — Slack Events API signing secret
   *   OPENAI_API_KEY        — OpenAI API key for the AI agent
   */
  "kv_namespaces": [
    {
      "binding": "SLACK_INSTALLATIONS",
      "id": "b0f86ee3621343fa9e51f3796f713c31"
    },
    {
      "binding": "CONVERSATIONS",
      "id": "9aea8fa50e1c4293b99716bc77ed74c9"
    },
    {
      "binding": "OAUTH_STATE",
      "id": "91c69ffb09e9427bb2beae4f8f662a1b"
    }
  ],
  "vars": {
    "LOGCLAW_ENDPOINT": "https://ticket.logclaw.ai"
  },
  "workers_dev": true,
  "routes": [
    {
      "pattern": "slack.logclaw.ai/*",
      "zone_name": "logclaw.ai"
    }
  ],
  "observability": {
    "enabled": true
  },
  "dev": {
    "port": 8788
  }
}
